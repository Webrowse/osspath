generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  companyStates UserCompanyState[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Company ─────────────────────────────────────────────────────────────────

enum RustLevel {
  NONE
  PARTIAL
  HEAVY
  CORE
}

enum CompanyType {
  STARTUP
  SCALEUP
  ENTERPRISE
  OPEN_SOURCE
  AGENCY
}

enum CompanyCategory {
  INFRASTRUCTURE
  DATABASES
  OBSERVABILITY
  SECURITY
  NETWORKING
  DEV_TOOLS
  SYSTEMS
  COMPILERS
  WEB3
  AI_INFRA
  CLOUD_PLATFORM
  OTHER
}

model Company {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  logoUrl     String?
  description String
  careersUrl  String
  loginUrl    String?
  tags        String[]
  remote      Boolean          @default(true)
  rustLevel   RustLevel        @default(NONE)
  atsProvider String?
  companyType CompanyType?
  isHiring    Boolean          @default(true)
  lastHiringCheckAt DateTime?
  category         CompanyCategory?
  juniorAccessible Boolean          @default(false)
  openSourceRepo   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  userStates    UserCompanyState[]
  opportunities Opportunity[]

  @@index([name])
  @@index([remote])
  @@index([rustLevel])
  @@index([isHiring])
  @@map("companies")
}

// ─── Opportunities ────────────────────────────────────────────────────────────

enum OpportunitySource {
  HN_HIRING
  CURATED
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  STAFF
}

enum RustSignal {
  CORE
  HIGH
  MEDIUM
  LOW
}

model Opportunity {
  id               String            @id @default(cuid())
  source           OpportunitySource
  sourceId         String?
  sourceUrl        String
  title            String
  companyName      String
  companyId        String?
  bodyText         String?           @db.Text
  location         String?
  salary           String?
  isRemote         Boolean           @default(false)
  tags             String[]
  experienceLevel  ExperienceLevel?
  rustSignal       RustSignal        @default(MEDIUM)
  baseQualityScore Int?
  isJuniorFriendly Boolean           @default(false)
  hasOssPath       Boolean           @default(false)
  postedAt         DateTime?
  expiresAt        DateTime?
  lastSeenAt       DateTime          @default(now())
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  company Company? @relation(fields: [companyId], references: [id])

  @@index([source, sourceId])
  @@index([isActive, baseQualityScore])
  @@index([isActive, postedAt])
  @@index([isActive, experienceLevel])
  @@index([isActive, rustSignal])
  @@index([isActive, isRemote])
  @@index([isActive, isJuniorFriendly])
  @@index([isActive, source])
  @@index([companyId])
  @@map("opportunities")
}

// ─── User Company State ───────────────────────────────────────────────────────

enum UserCompanyStatus {
  NOT_APPLIED
  SAVED
  APPLIED
  OA
  RECRUITER_CALL
  INTERVIEWING
  FINAL_ROUND
  OFFER
  REJECTED
  GHOSTED
  NO_OPENINGS
  HIRING_FREEZE
  NOT_INTERESTED
}

model UserCompanyState {
  id        String            @id @default(cuid())
  userId    String
  companyId String

  status UserCompanyStatus @default(NOT_APPLIED)

  appliedAt         DateTime?
  rejectedAt        DateTime?
  offerReceivedAt   DateTime?
  lastCheckedAt     DateTime?
  lastOpeningSeenAt DateTime?
  followUpAt        DateTime?
  remindAfterDays   Int?

  recruiterName     String?
  notes             String?   @db.Text
  salaryExpectation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, appliedAt])
  @@index([userId, lastCheckedAt])
  @@index([userId, followUpAt])
  @@index([userId, updatedAt])
  @@map("user_company_states")
}
