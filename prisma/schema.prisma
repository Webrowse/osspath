generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Published content ─────────────────────────────────────────────────────────
// One row per published item. `data` holds the full JSON object as-is.
// `href` is extracted for fast dedup lookups.

model ContentItem {
  id        String   @id @default(cuid())
  type      String   // "jobs" | "oss" | "grants" | "pulse" | "events" | "companies" | "portals"
  href      String?
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([type])
  @@index([type, href])
  @@map("content_items")
}

// ── Schema guardrail ──────────────────────────────────────────────────────────
// Single row recording the fingerprint (normalised hash) of the schema last
// intentionally applied, plus the git commit it came from. Written automatically
// by `npm run db:apply`. The admin dashboard compares this to the running app's
// schema fingerprint to detect a database applied from a stale checkout.

model SchemaMetadata {
  id          String   @id @default("singleton")
  fingerprint String
  gitCommit   String?
  updatedAt   DateTime @updatedAt
  @@map("schema_metadata")
}

// ── Pipeline: managed sources ─────────────────────────────────────────────────
// Replaces hardcoded scanner constants. Each row is one source the pipeline
// scans. `fingerprint` and `lastRunAt` are the incremental watermark (RSS URL,
// thread id, ETag, or last-run timestamp) so unchanged sources become no-ops.

model Source {
  id            String    @id @default(cuid())
  type          String    // ContentType this source feeds
  kind          String    // scanner kind: github-search | github-org | twir | hn | reddit | greenhouse | lever | events | portals | rust-bytes
  label         String
  url           String?   // query string, org slug, feed URL, or ATS slug
  parser        String?   // optional parser id
  enabled       Boolean   @default(true)
  intervalHours Int       @default(24)
  fingerprint   String?   // last-seen watermark for incremental scans
  lastRunAt     DateTime?
  config        Json?     // extra per-source configuration
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([type, enabled])
  @@map("sources")
}

// ── Pipeline: allow / block lists ─────────────────────────────────────────────
// Checked before expensive work. Grown manually and automatically (the reviewer
// blocklists spam). Single source of truth for "never process this again".

model ListEntry {
  id        String   @id @default(cuid())
  kind      String   // allow | block
  target    String   // repo | company | domain | url | org | topic | keyword | author
  value     String
  reason    String?  // why this entry exists
  source    String?  // manual | reviewer
  createdAt DateTime @default(now())
  @@unique([kind, target, value])
  @@index([kind, target])
  @@map("list_entries")
}

// ── Pipeline: run records + lock ──────────────────────────────────────────────
// One row per Refresh. Also serves as the run lock: a fresh `running` row blocks
// concurrent runs; a stale heartbeat lets a new run take over a crashed one.

model PipelineRun {
  id         String    @id @default(cuid())
  status     String    @default("running") // running | done | failed
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  heartbeat  DateTime  @default(now())
  dirty      Boolean   @default(false)
  report     Json?     // added / removed / skipped / errors summary
  createdAt  DateTime  @default(now())
  @@index([status])
  @@map("pipeline_runs")
}

// ── Publishing: last Git snapshot ─────────────────────────────────────────────
// Single row recording the last successful publish of the content snapshot to
// Git: the commit SHA, a SHA-256 of the published canonical content, and when it
// happened. Postgres stays the source of truth; this is bookkeeping so the admin
// can see which Git commit is currently live. Written only on a successful push.

model PublishMetadata {
  id                String    @id @default("singleton")
  lastCommitSha     String?
  lastContentSha256 String?
  lastPublishedAt   DateTime?
  updatedAt         DateTime  @updatedAt
  @@map("publish_metadata")
}

// ── Tier 2: Knowledge Graph snapshot ──────────────────────────────────────────
// Single row holding the current corpus-wide knowledge graph (typed nodes +
// typed edges), derived entirely from Tier 1 and Tier 2 data already stored on
// content_items. Deterministic and idempotent: recomputing an unchanged corpus
// yields an identical contentHash and no write. Independent from export/UI -
// nothing reads this yet. nodeCount/edgeCount/contentHash are duplicated out of
// `data` as scalar columns purely for cheap inspection without parsing the JSON.

model GraphSnapshot {
  id          String   @id @default("singleton")
  version     Int
  nodeCount   Int
  edgeCount   Int
  contentHash String
  data        Json
  computedAt  DateTime
  updatedAt   DateTime @updatedAt
  @@map("graph_snapshots")
}

// ── Overrides: manual configuration, not content ──────────────────────────────
// Small hand-curated exception datasets layered on top of automatic pipeline
// output (e.g. a manual ecosystem-tag correction, a tracked company
// acquisition). Deliberately NOT a ContentItem: overrides are configuration
// admins tune directly, not discovered/published editorial content, so they
// get their own lightweight table and purpose-built editors instead of the
// generic Published CRUD screen. `kind` discriminates the override family;
// `key` is a natural dedup key scoped to that kind (e.g. "owner/repo" for
// eco-tags, "edge_type:from:to" for lifecycle-edges); `data` holds the rest.

model Override {
  id        String   @id @default(cuid())
  kind      String   // "eco-tags" | "lifecycle-edges"
  key       String   // dedup key, meaning is kind-specific
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([kind, key])
  @@index([kind])
  @@map("overrides")
}
