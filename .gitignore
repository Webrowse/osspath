# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# OpenNext
.open-next

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env.local
.aider*

# research and planning docs (root only, named with underscores)
/[A-Z]*_*.md
/[A-Z]*_*.json
/posthog-setup-report.md

# generated cache
/data/oss-deps-cache.json

# NOTE: the scanner-generated dataset (content/{jobs,oss,grants,pulse,events,
# companies,portals,news}.json) is now a TRACKED published snapshot. PostgreSQL
# is the source of truth; the Refresh pipeline exports the canonical snapshot
# and commits it to Git, and the build consumes it. See lib/pipeline/snapshot.ts.

# search index - regenerated at build by scripts/build-search-index.mjs
/public/search-index.json
