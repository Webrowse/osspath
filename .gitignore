# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# OpenNext
.open-next

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env.local
.aider*

# research and planning docs (root only, named with underscores)
/[A-Z]*_*.md
/[A-Z]*_*.json
/posthog-setup-report.md

# generated cache
/data/oss-deps-cache.json

# admin scratch — pending/rejected are local-only; only content/ is deployed
/data/pending/
/data/rejected/
/data/enrich.log

# scanner-generated dataset — lives in PostgreSQL, materialised at build time
# by scripts/export-db-to-json.mjs. Not committed so the repo does not carry
# the curated dataset. Editorial content (authors, learning, funders, programs,
# lifecycle-edges, eco-overrides) and derived oss-* indexes stay tracked.
/content/jobs.json
/content/oss.json
/content/grants.json
/content/pulse.json
/content/events.json
/content/companies.json
/content/portals.json
/content/news.json

# search index — regenerated at build by scripts/build-search-index.mjs
/public/search-index.json
